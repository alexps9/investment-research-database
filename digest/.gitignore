# Secrets — never commit
.env
.env.local
.env.*.local
.env.bak.*
*.pem
*.key
.lark-cli/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
.uv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data — ONLY digests/ and signal_sources/ are committed. The daily briefs are
# the product, kept in-repo so the KB can extract/process signals from them.
# Everything else under data/ (caches, dedup DBs, candidate pools, logs, PDF
# artifacts, run state) is regenerated by the pipeline and must not be committed.
data/*
!data/digests/
!data/signal_sources/

# IDE / OS
.DS_Store
.vscode/
.idea/
.obsidian/

# Backups (prompt / digest version snapshots — not committed)
*.bak
*.bak-*

# Build
dist/
build/
*.egg-info/
