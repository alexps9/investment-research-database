# Copy to .env and fill in actual values. NEVER commit .env.

# X data source (via socialdata.tools, PAYG)
# Sign up at https://socialdata.tools/signup
SOCIALDATA_API_KEY=your_socialdata_key_here
SOCIALDATA_BASE_URL=https://api.socialdata.tools

# Anthropic (Claude)
# Sign up at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Feishu — using lark-cli --profile personal for user auth
# Run `lark-cli auth login` first. No Feishu secrets here.

# Feishu enterprise bot — HRes' aha moment (1-on-1 subscription push)
# Create app at https://open.feishu.cn/app → enable 机器人 + scope im:message:send_as_bot
FEISHU_BOT_APP_ID=
FEISHU_BOT_APP_SECRET=
# Comma-separated open_ids of HH Research team members (under this bot's app):
FEISHU_BOT_RECIPIENT_OPENIDS=

# Bitable target (obj_token of the "信号" Base)
HH_BITABLE_APP_TOKEN=
HH_WIKI_SPACE_ID=
HH_WHITELIST_TABLE_ID=

# Paths
HH_DATA_DIR=./data
HH_LOG_DIR=./data/logs

# Timezone
HH_TIMEZONE=Asia/Shanghai

# H Link (HCMLink, 高瓴有数) — 1-on-1 textcard push
# Apply via IT: create a 轻应用 named "HRes' aha moment" at open-ushu.hillinsight.tech.
# IT will provide app_id / app_key / app_secret / portal + team open_id list.
# Leave empty until credentials arrive; broadcast_today.sh skips H Link push if empty.
H_LINK_BASE_URL=https://open-ushu.hillinsight.tech
H_LINK_APP_ID=
H_LINK_APP_KEY=
H_LINK_APP_SECRET=
H_LINK_PORTAL=
# Comma-separated H Link open_ids of HH Research team members:
H_LINK_RECIPIENT_OPENIDS=
