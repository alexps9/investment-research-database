# ── LLM (shared project model client; DeepSeek by default) ──────────────
# Used by the AutoGen alert_agent for judge / summary / review.
LLM_API_KEY=your_deepseek_or_openai_compatible_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Knowledge base backend (where signals are persisted) ────────────────
KB_API_BASE_URL=http://localhost:8000

# ── Signal sources ──────────────────────────────────────────────────────
# X / Twitter fetch (twitterapi.io). Leave unset to run RSS + media only.
TWITTERAPI_IO_KEY=your_key_here

# ── Outbound push ───────────────────────────────────────────────────────
# Feishu/Lark incoming webhook. Leave unset for dry-run (prints, never sends).
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_id
