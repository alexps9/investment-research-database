# ============================================
# Academic Paper Analysis - Environment Variables
# ============================================
# Copy this file to .env and adjust values as needed

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
# Options: debug, info, warning, error
# - debug: Detailed logs for development
# - info: Standard production logs
# - warning: Only warnings and errors
# - error: Only critical errors
LOG_LEVEL=info

# --------------------------------------------
# Backend Configuration
# --------------------------------------------
BACKEND_PORT=8000

# OpenAlex API User Agent (required for polite pool)
# Format: ApplicationName/Version (contact:email)
# See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_USER_AGENT=product@miracleplus.com

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
FRONTEND_PORT=3000

# Backend API URL (use http://backend:8000 in Docker, http://localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=http://backend:8000

# --------------------------------------------
# Node Environment
# --------------------------------------------
# Options: development, staging, production
# - development: Enables debug features, verbose logging
# - staging: Production-like environment for testing
# - production: Optimized for performance, minimal logging
NODE_ENV=production
