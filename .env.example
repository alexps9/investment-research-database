# =============================================================================
# 环境配置模板  |  复制本文件为 .env 并填入真实密码后使用
# 预设方案：
#   [supabase+render]  Supabase PostgreSQL + Render.com 后端 + GitHub Pages 前端
#   [aws-dev]          EC2 连 AWS 托管资源（RDS / ElastiCache / S3）
#   [local]            本地 docker-compose --profile local
# =============================================================================

# -----------------------------------------------------------------------------
# [supabase+render]  免费公开部署方案
# 前端 → GitHub Pages (alexps9.github.io/investment-research-database)
# 后端 → Render.com  (https://hh-research-backend.onrender.com)
# 数据库 → Supabase PostgreSQL
# -----------------------------------------------------------------------------
# 在 Supabase 控制台 → Project Settings → Database → Connection string 找到以下信息
#   项目 ref: xxxxxxxxxxxxxxxx
#   DB密码:   <your-db-password>
#   区域:     aws-0-ap-southeast-1 (根据实际选择)
#
# asyncpg（后端异步 ORM 使用）:
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# psycopg2（Alembic 迁移使用）:
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# SSL: Supabase 强制 TLS，必须设为 require
# DB_SSL_MODE=require
#
# 前端指向 Render 后端（在 GitHub repo Settings → Variables → NEXT_PUBLIC_API_URL 设置）:
# NEXT_PUBLIC_API_URL=https://hh-research-backend.onrender.com
#
# 运行迁移（本地执行，指向 Supabase）:
#   cd backend
#   DATABASE_URL_SYNC=postgresql+psycopg2://... DB_SSL_MODE=require alembic upgrade head
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# [aws-dev] 在公司 EC2 上连接 AWS 托管资源时使用以下配置
# -----------------------------------------------------------------------------

# PostgreSQL — Amazon RDS for PostgreSQL (ap-southeast-1, port 54321)
DATABASE_URL=postgresql+asyncpg://singalsysdevadmin:<PASSWORD>@singalsysdevdb.cluster-cbui0oeeppnh.ap-southeast-1.rds.amazonaws.com:54321/ai_knowledge
DATABASE_URL_SYNC=postgresql+psycopg2://singalsysdevadmin:<PASSWORD>@singalsysdevdb.cluster-cbui0oeeppnh.ap-southeast-1.rds.amazonaws.com:54321/ai_knowledge

# Redis — Amazon ElastiCache (写主节点；只读流量可改用 Reader Endpoint)
# Primary : ecrg-singalsys-dev.faqlgj.ng.0001.apse1.cache.amazonaws.com:6379
# Reader  : ecrg-singalsys-dev-ro.faqlgj.ng.0001.apse1.cache.amazonaws.com:6379
REDIS_URL=redis://ecrg-singalsys-dev.faqlgj.ng.0001.apse1.cache.amazonaws.com:6379/0

# S3 — 留空 S3_ENDPOINT_URL 表示使用真实 AWS S3（不走 MinIO）
# EC2 上建议挂 IAM Role，AWS_ACCESS_KEY_ID / SECRET 留空即可自动鉴权
S3_ENDPOINT_URL=
S3_BUCKET=hcp-singalsys-dev
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# [local] 本地 docker-compose --profile local 启动时使用以下配置
# （把上面三段替换成下面注释掉的值即可）
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_knowledge
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_knowledge
# REDIS_URL=redis://localhost:6379/0
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=hh-research
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# 通用配置（两套环境相同）
# -----------------------------------------------------------------------------
DEBUG=false

# PostgreSQL connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# SSL:
#   "disable" - 本地 docker
#   "require" - AWS RDS（TLS 必需，不校验证书链）
DB_SSL_MODE=require

# pgvector 向量维度（必须与 pipeline 使用的 embedding 模型一致）
# 1536 = OpenAI text-embedding-3-small / ada-002
# 3072 = OpenAI text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
