# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_knowledge
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_knowledge
DEBUG=false

# PostgreSQL connection pool (defaults work for local dev; tune for RDS instance class)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# SSL mode for asyncpg:
#   "disable"     - local docker (no TLS)
#   "require"     - Amazon RDS (TLS, no cert verification)
#   "verify-full" - Amazon RDS with RDS CA bundle downloaded
DB_SSL_MODE=disable

# pgvector: must match the embedding model used by the pipeline
# 1536 = OpenAI text-embedding-3-small / ada-002
# 3072 = OpenAI text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# Redis (local: docker compose 'redis' service; prod: Amazon ElastiCache endpoint)
REDIS_URL=redis://localhost:6379/0

# Object storage (local: MinIO; prod: Amazon S3 -- leave S3_ENDPOINT_URL empty for real S3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=hh-research
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
