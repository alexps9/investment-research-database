# Server .env — copy to deploy/.env on the host and fill in real secrets.
# Consumed by docker-compose.server.yml. NEVER commit the real .env.

# ── Supabase PostgreSQL (session pooler) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
DB_SSL_MODE=require

# ── Embeddings (semantic search). SiliconFlow bge-m3, 1024 dims. ────────
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ── LLM via LiteLLM gateway → AWS Bedrock (Claude) ──────────────────────
# The gateway speaks the OpenAI API; backend + agent point their base_url at it.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION_NAME=us-east-1
# AWS Bedrock geo-blocks mainland-China IPs for Anthropic Claude. Set an overseas
# HTTP/HTTPS proxy so the gateway's Bedrock calls egress from a supported region,
# e.g. http://user:pass@host:port  (leave empty if the host already has overseas egress).
BEDROCK_PROXY_URL=
# Master key clients must send (any sk-... string you choose).
LITELLM_MASTER_KEY=sk-hh-litellm-changeme
# Backend chat (reads DEEPSEEK_* + LLM_MODEL) → gateway:
DEEPSEEK_API_KEY=${LITELLM_MASTER_KEY}
DEEPSEEK_BASE_URL=http://litellm:4000/v1
LLM_MODEL=claude-sonnet-4-6
# Agent (reads LLM_*) → gateway (LLM_BASE_URL is also set in compose):
LLM_API_KEY=${LITELLM_MASTER_KEY}
LLM_BASE_URL=http://litellm:4000/v1

# ── Agent pipelines (optional) ──────────────────────────────────────────
FEISHU_WEBHOOK_URL=
TWITTERAPI_IO_KEY=
